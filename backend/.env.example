# ==============================================
# TradeWise AI Backend - Environment Variables
# ==============================================
# Copy this file to .env and fill in your values
# ==============================================

# Server Configuration
PORT=3000
NODE_ENV=development

# MongoDB Connection
# Local: mongodb://localhost:27017/tradewise
# Atlas: mongodb+srv://user:pass@cluster.mongodb.net/tradewise
MONGODB_URI=mongodb://localhost:27017/tradewise

# JWT Authentication
# Generate a secure random string (min 32 chars)
JWT_SECRET=your-super-secret-jwt-key-change-this

# ==============================================
# AI Service API Keys
# ==============================================

# Google Gemini API (Required for AI coaching)
# Get key: https://aistudio.google.com/app/apikey
GOOGLE_AI_API_KEY=

# Hugging Face API (Required for emotion detection)
# Get key: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=

# Cohere API (Required for term explanations)
# Get key: https://dashboard.cohere.com/api-keys
COHERE_API_KEY=

# ==============================================
# Email Configuration (Optional)
# ==============================================
# Required for pre-market briefings and alerts
# If not configured, briefings will be logged to console

# SMTP Settings (Gmail example)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="TradeWise AI" <coach@tradewise.ai>

# ==============================================
# Optional: External Price APIs
# ==============================================
# CoinGecko is used by default (no key required for basic usage)
# COINGECKO_API_KEY=
