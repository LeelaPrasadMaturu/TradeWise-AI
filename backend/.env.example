# ==============================================
# TradeWise AI Backend - Environment Variables
# ==============================================
# Copy this file to .env and fill in your values
# Run: node scripts/verify-env.js to test all APIs
# ==============================================

# ==============================================
# REQUIRED - Core Settings
# ==============================================

# Server Configuration
PORT=3000
NODE_ENV=development

# MongoDB Connection
# Local: mongodb://localhost:27017/tradewise
# Atlas: mongodb+srv://user:pass@cluster.mongodb.net/tradewise
MONGODB_URI=mongodb://localhost:27017/tradewise

# JWT Authentication
# Generate a secure random string (min 32 chars)
# You can generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# ==============================================
# REQUIRED - AI Service API Keys
# ==============================================
# Without these, core features will not work!

# Google Gemini API (REQUIRED)
# Used for: Post-trade analysis, Weekly insights, Quiz generation, Pre-market briefings
# Get key: https://aistudio.google.com/app/apikey
# Cost: Free tier available (60 requests/min)
GOOGLE_AI_API_KEY=

# Hugging Face API (OPTIONAL but recommended)
# Used for: FinBERT emotion detection in trade reasons
# Without this: Falls back to keyword-based emotion detection
# Get key: https://huggingface.co/settings/tokens
# Cost: Free tier available
HUGGINGFACE_API_KEY=

# Cohere API (OPTIONAL)
# Used for: Term explanations in learning section
# Without this: Term explanations won't work
# Get key: https://dashboard.cohere.com/api-keys
# Cost: Free tier available (100 API calls/min)
COHERE_API_KEY=

# ==============================================
# OPTIONAL - Email Configuration
# ==============================================
# Required for: Pre-market briefing emails, weekly report emails
# If not configured: Briefings will only show in dashboard, no emails sent

# SMTP Settings (Gmail example)
# For Gmail: Enable 2FA, then create App Password at https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM="TradeWise AI" <coach@tradewise.ai>

# ==============================================
# OPTIONAL - External APIs
# ==============================================

# CoinGecko (no key required for basic usage)
# COINGECKO_API_KEY=
