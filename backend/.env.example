# =============================================================================
# TradeWise AI - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values
# cp .env.example .env

# =============================================================================
# Server Configuration
# =============================================================================
NODE_ENV=development
PORT=3000

# =============================================================================
# MongoDB Configuration
# =============================================================================
MONGODB_URI=mongodb://localhost:27017/tradewise

# For replica sets (production):
# MONGODB_URI=mongodb://mongo-0:27017,mongo-1:27017,mongo-2:27017/tradewise?replicaSet=rs0

# =============================================================================
# Redis Configuration
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_QUEUE_DB=1
REDIS_KEY_PREFIX=tradewise:

# For Redis Cluster (production):
# REDIS_CLUSTER_NODES=redis-0:6379,redis-1:6379,redis-2:6379

# TLS (for managed Redis):
# REDIS_TLS=true

# =============================================================================
# Apache Kafka Configuration
# =============================================================================
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=tradewise-api
KAFKA_GROUP_ID=tradewise-workers

# For multiple brokers:
# KAFKA_BROKERS=kafka-0:9092,kafka-1:9092,kafka-2:9092

# SASL Authentication (for managed Kafka):
# KAFKA_SSL=true
# KAFKA_SASL_MECHANISM=plain
# KAFKA_SASL_USERNAME=your_username
# KAFKA_SASL_PASSWORD=your_password

# =============================================================================
# JWT Authentication
# =============================================================================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# =============================================================================
# AI Service API Keys
# =============================================================================
# Google Gemini - For post-trade analysis, insights, quiz/flashcard generation
GOOGLE_AI_API_KEY=your_google_gemini_api_key

# Hugging Face - For FinBERT emotion detection
HUGGINGFACE_API_KEY=your_huggingface_api_key

# Cohere - For trading term explanations
COHERE_API_KEY=your_cohere_api_key

# =============================================================================
# Email Configuration (SMTP)
# =============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="TradeWise AI <coach@tradewise.ai>"

# =============================================================================
# Observability
# =============================================================================
# Prometheus metrics endpoint (enabled by default)
METRICS_ENABLED=true

# Jaeger tracing
JAEGER_AGENT_HOST=localhost
JAEGER_AGENT_PORT=6831

# Tracing sample rate (0.0 to 1.0)
TRACING_SAMPLE_RATE=0.1

# =============================================================================
# Rate Limiting
# =============================================================================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Token bucket settings
RATE_LIMIT_CAPACITY=60
RATE_LIMIT_REFILL_RATE=1

# =============================================================================
# Worker Configuration
# =============================================================================
# AI Worker concurrency
AI_WORKER_CONCURRENCY=5

# Email Worker concurrency
EMAIL_WORKER_CONCURRENCY=3

# Pattern Detection Worker concurrency
PATTERN_WORKER_CONCURRENCY=3

# =============================================================================
# Circuit Breaker Configuration
# =============================================================================
# Failure threshold before opening circuit
CIRCUIT_BREAKER_THRESHOLD=5

# Reset timeout in milliseconds
CIRCUIT_BREAKER_RESET_TIMEOUT=30000

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=info

# For production:
# LOG_LEVEL=warn

# =============================================================================
# Frontend URL (for CORS)
# =============================================================================
FRONTEND_URL=http://localhost:3001

# =============================================================================
# Feature Flags
# =============================================================================
ENABLE_KAFKA=true
ENABLE_REDIS=true
ENABLE_METRICS=true
ENABLE_TRACING=true
