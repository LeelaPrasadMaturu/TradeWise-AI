{
  "name": "tradewise-ai",
  "version": "1.2.1",
  "description": "TradeWise AI - Intelligent Trading Journal with Behavioral Analytics",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently -n backend,frontend -c blue,green \"npm run dev -w backend\" \"npm run dev -w frontend\"",
    "dev:backend": "npm run dev -w backend",
    "dev:frontend": "npm run dev -w frontend",
    "start:backend": "npm run start -w backend",
    "start:frontend": "npm run start -w frontend",
    "build:frontend": "npm run build -w frontend",
    "test": "npm run test -w backend",
    "test:coverage": "npm run test:coverage -w backend",
    "install:all": "npm install"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
